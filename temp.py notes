thermistor = adafruit_thermistor.Thermistor(
    board.TEMPERATURE, 10000, 10000, 25, 3950)

pixels = neopixel.NeoPixel(board.NEOPIXEL, 10, brightness=.05, auto_write=False)
pixels.fill((0, 0, 0))
pixels.show()

# try to make a list with these values 
lagoon_blue = (77, 147, 221)
turquoise = (75, 220, 227)
water_leaf = (161, 237, 222)
green_yellow = (239, 242, 177)
vibrant_gold = (255, 213, 18)
red =(245, 59, 59)
smooth_red = (195, 18, 32)
off = (0,0,0)

colors = [lagoon_blue, turquoise, water_leaf, green_yellow, vibrant_gold, red , smooth_red]


def pixel_color(temp_f):
    # FIRST TO TURN OFF THE PIXELS!!!!!!!!!
    pixels.fill(0)
    
    # write if statments to equal items in the list
    
    if temp_f > 90:
        num_color = 6
        
    elif temp_f > 82.5:
        num_color = 5
        
    elif temp_f > 75:
        num_color = 4
        
    elif temp_f > 67.5:
        num_color = 3
        
    elif temp_f > 60:
        num_color = 2
        
    elif temp_f > 52.5:
        num_color = 1
        
    elif temp_f > 45:
        num_color = 0
        
    for num in range (num_color +1):
        pixels[num] = colors[num]
        
    return pixels

while True:
    temp_c = thermistor.temperature
    temp_f = thermistor.temperature * 9 / 5 + 32
    print("Temperature is: %f C and %f F" % (temp_c, temp_f))
    
    pixel_color(temp_f)

    time.sleep(0.25)
    pixels.show()

        
        
        
