# Circuit Playground Light Sensor
# Reads the on-board light sensor and graphs the brightness with NeoPixels

import time
import board
import neopixel
import analogio
import simpleio   # Not a circuit python lib
from digitalio import DigitalInOut, Direction, Pull

pixels = neopixel.NeoPixel(board.NEOPIXEL, 10, brightness=.05, auto_write=False)
pixels.fill((0, 0, 0))
pixels.show()

light = analogio.AnalogIn(board.LIGHT)   # Measure light give a number between 0 and 65535
switch = DigitalInOut(board.D7)
switch.direction = Direction.INPUT
switch.pull = Pull.UP

while True:
    # light value remapped to pixel position
    peak = simpleio.map_range(light.value, 2000, 62250, 0, 10) # Takes the value fromlight and changes it to be 0-9
    print("This is the pixel we'll map to: ",peak)
    print(light.value)
    print(int(peak))
    
    
    if switch.value:         # switch on
        for i in range(0, 10):
            if 2 < peak:    # If the peak light value is larger than the number of pixels, light up that many pixels
                pixels[i] = (0,0,0)
                #pixels.fill
                
            else:
                pixels[0] = (250, 0, 0)
                pixels[1] = (0, 250, 0)
                pixels[2] = (250, 0, 250)# magenta
                pixels[3] = (0, 0, 250)
                pixels[4] = (500, 500, 250)
                pixels[5] = (250, 0, 0)
                pixels[6] = (0, 250, 0)
                pixels[7] = (250, 0, 250)
                pixels[8] = (0, 0, 250)
                pixels[9] = (500, 500, 250)        
        pixels.show()
        time.sleep(0.01)
    else:
        for i in range (0,10):
            pixels[i] = (0,0,0)
    
